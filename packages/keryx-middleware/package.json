{
  "name": "@keryxhq/middleware",
  "version": "0.1.1",
  "description": "Turn any HTTP handler into a paid tool for AI agents. Speaks x402, verifies EIP-3009 USDC authorizations, settles on Arc.",
  "keywords": [
    "x402",
    "eip-3009",
    "mcp",
    "agents",
    "ai-agents",
    "usdc",
    "arc",
    "arc-network",
    "circle",
    "keryx",
    "kēryx",
    "paid-api",
    "nanopayments",
    "api-monetization",
    "402",
    "stablecoins"
  ],
  "author": {
    "name": "Kēryx",
    "url": "https://keryxhq.xyz"
  },
  "license": "MIT",
  "homepage": "https://keryxhq.xyz/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cryptoduke01/keryx.git",
    "directory": "packages/keryx-middleware"
  },
  "bugs": {
    "url": "https://github.com/cryptoduke01/keryx/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "viem": "^2.21.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  }
}
