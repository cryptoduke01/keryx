# --- Arc / Keryx (Lepton product) ---
# Active settlement network: testnet (default) | mainnet (only when ready)
# NEXT_PUBLIC_ARC_NETWORK=testnet
# Local facilitator (preferred when set): real EIP-3009 USDC on active Arc network.
# KERYX_FACILITATOR_PRIVATE_KEY=
# NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
# NEXT_PUBLIC_ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
# Mainnet (enable only when Circle publishes public chain params):
# NEXT_PUBLIC_ARC_MAINNET_READY=true
# NEXT_PUBLIC_ARC_MAINNET_CHAIN_ID=
# NEXT_PUBLIC_ARC_MAINNET_RPC_URL=
# NEXT_PUBLIC_ARC_MAINNET_USDC=0x3600000000000000000000000000000000000000
# NEXT_PUBLIC_ARC_MAINNET_EXPLORER=https://arcscan.app
# NEXT_PUBLIC_KERYX_TREASURY_ADDRESS=
# NEXT_PUBLIC_REGISTRY_ADDRESS=

# Upstash Redis (ledger, registry store, publish nonces).
# Console: https://console.upstash.com → Redis → REST API
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# Circle Gateway (opt-in). Only used when CIRCLE_GATEWAY_PREFERRED=true
# OR when no local facilitator key is set.
# CIRCLE_GATEWAY_API_URL=
# CIRCLE_GATEWAY_PREFERRED=false
# CIRCLE_ARC_PRIVATE_MAINNET=false

# --- OKX.AI ASP / X Layer (parallel feature — does not replace Arc) ---
# Get keys: https://web3.okx.com/onchainos/dev-docs/home/developer-portal
# 1. Connect wallet → verify
# 2. Link email + phone
# 3. Create API key (you choose the passphrase — save it)
# 4. View details → copy secret key
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# Wallet that receives ASP fees (Agentic Wallet address or any EVM address)
OKX_PAY_TO_ADDRESS=
# eip155:1952 = X Layer testnet (start here) | eip155:196 = mainnet
OKX_X402_NETWORK=eip155:1952
# Optional: 64-char hex for MPP charge challenge signing.
# If unset, derived from OKX_SECRET_KEY (stable). Seller docs also accept MPPX_SECRET_KEY.
# MPP_SECRET_KEY=
